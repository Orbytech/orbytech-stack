{
  "name": "@orbytech/sdk",
  "version": "0.1.0",
  "description": "Shared TypeScript SDK for OrbyTech applications",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "stellar-sdk": "^12.0.0",
    "axios": "^1.6.7",
    "zod": "^3.22.4",
    "soroban-client": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/jest": "^29.5.12",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
