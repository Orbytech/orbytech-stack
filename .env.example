# Environment Variables Example
# Copy this file to .env and fill in your values

# Application Configuration
NODE_ENV=development
PORT=3001
WEB_PORT=3000

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Stellar Account Configuration (for development)
STELLAR_SECRET_KEY=your_secret_key_here
STELLAR_PUBLIC_KEY=your_public_key_here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/orbytech
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# API Keys
STELLAR_API_KEY=your_stellar_api_key_here
WEB3_STORAGE_API_KEY=your_web3_storage_api_key_here

# Third-party Services
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=info

# Contract Configuration
PAYMENT_CONTRACT_ID=your_payment_contract_id_here
STREAMING_CONTRACT_ID=your_streaming_contract_id_here

# Development Tools
ENABLE_CORS=true
ENABLE_LOGGING=true
ENABLE_METRICS=true

# Production Configuration (uncomment for production)
# NODE_ENV=production
# STELLAR_NETWORK=mainnet
# STELLAR_HORIZON_URL=https://horizon.stellar.org
# STELLAR_SOROBAN_RPC_URL=https://soroban.stellar.org
# STELLAR_NETWORK_PASSPHRASE="Public Global Stellar Network ; September 2015"
# LOG_LEVEL=error
# ENABLE_CORS=false
